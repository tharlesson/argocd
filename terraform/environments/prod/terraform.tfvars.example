region          = "us-east-1"
environment     = "prod"
cluster_name    = "gitops-prod"
domain_name     = "example.internal"
gitops_repo_url = "https://github.com/your-org/argocd-gitops.git"

azs = [
  "us-east-1a",
  "us-east-1b",
  "us-east-1c"
]

vpc_cidr = "10.0.0.0/16"

private_subnets = [
  "10.0.1.0/24",
  "10.0.2.0/24",
  "10.0.3.0/24"
]

public_subnets = [
  "10.0.101.0/24",
  "10.0.102.0/24",
  "10.0.103.0/24"
]

node_instance_types = ["t3.large"]
node_min_size       = 2
node_desired_size   = 3
node_max_size       = 6

ecr_repositories = ["sample-api"]

tags = {
  Owner       = "platform-team"
  CostCenter  = "engineering"
  Repository  = "argocd-gitops"
}
